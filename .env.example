OPENAI_API_KEY=your-openai-key-here
GEMINI_API_KEY=your-gemini-key-here
ANTHROPIC_API_KEY=your-anthropic-key-here

# Embedding provider: openai | gemini | anthropic
EMBED_PROVIDER=openai

# Paths
DATA_PATH=./data
VECTOR_STORE_PATH=./artifacts/vector_store
CALIBRATION_PATH=./artifacts/calibration

# Quality Gates
MIN_WORD_COUNT=30
MIN_RETENTION_RATIO=0.15

# Chunking
CHUNK_SIZE=400
CHUNK_OVERLAP=80
